{
  "name": "production-playwright-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
  "clean:allure": "rm -rf allure-results allure-report",
  "test": "npm run clean:allure && npx playwright test",
  "test:ui": "npm run clean:allure && npx playwright test --grep @ui",
  "test:api": "npm run clean:allure && npx playwright test --grep @api",
  "test:perf": "npm run clean:allure && npx playwright test --grep @perf",
  "report": "allure generate ./allure-results --clean -o ./allure-report",
  "report:open": "allure open ./allure-report"
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/newazCS/production-playwright-framework.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/newazCS/production-playwright-framework/issues"
  },
  "homepage": "https://github.com/newazCS/production-playwright-framework#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "allure-js-commons": "^3.6.0",
    "allure-playwright": "^3.6.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
