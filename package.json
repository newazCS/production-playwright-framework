{
  "name": "production-playwright-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean:allure": "rm -rf allure-results allure-report",
    "test": "npm run clean:allure && npx playwright test",
    "test:ui": "npm run clean:allure && npx playwright test --grep @ui",
    "test:api": "npm run clean:allure && npx playwright test --grep @api",
    "test:perf": "npm run clean:allure && npx playwright test --grep @perf",
    "report": "npm run allure:normalize && allure generate ./allure-results --clean -o ./allure-report",
    "report:open": "allure open ./allure-report",
    "allure:normalize": "node scripts/normalizeAllureHierarchy.js",
    "validate:env": "node -e \"require('./dist/config/validateEnv')\"",
    "bdd": "npx cucumber-js --require-module ts-node/register",
    "bdd:sauceDemo": "npx cucumber-js --require-module ts-node/register --tags @saucedemo",
    "bdd:greenKart": "npx cucumber-js --require-module ts-node/register --tags @greenkart"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/newazCS/production-playwright-framework.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/newazCS/production-playwright-framework/issues"
  },
  "homepage": "https://github.com/newazCS/production-playwright-framework#readme",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "allure-cucumberjs": "^3.6.0",
    "allure-js-commons": "^3.6.0",
    "allure-playwright": "^3.6.0",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
